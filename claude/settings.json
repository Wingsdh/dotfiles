{
  "permissions": {
    "allow": [
      "Skill",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "mcp__pencil"
    ]
  },
  "enabledPlugins": {
    "obsidian@obsidian-skills": true,
    "skill-creator@claude-plugins-official": true,
    "claude-tmux@claude-tmux": true,
    "bay-development@ai-dev-kit": true,
    "bay-lab-commands@ai-dev-kit": true,
    "bay-product-design@ai-dev-kit": true
  },
  "extraKnownMarketplaces": {
    "wings-claude-skills": {
      "source": {
        "source": "git",
        "url": "git@github.com:Wingsdh/wings-claude-skills.git"
      },
      "autoUpdate": true
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      },
      "autoUpdate": true
    },
    "claude-tmux": {
      "source": {
        "source": "github",
        "repo": "Wingsdh/claude-tmux"
      }
    },
    "ai-dev-kit": {
      "source": {
        "source": "directory",
        "path": "/Users/wings/AI-Workspace/ai-builder/ai-dev-kit"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "python-vibecoding": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "/Users/wings/Code/ai-coding/python-vibecoding-mcp-server",
        "run",
        "mcp_server.py"
      ]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ]
    }
  }
}
